<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1FEF4444" />
            <stroke android:width="1dp" android:color="#30EF4444" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0DEF4444" />
            <stroke android:width="1dp" android:color="#20EF4444" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
