<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:gravity="center_horizontal">

    <!-- ══ HEADER BAR — warna ikut colorHeaderBg ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorHeaderBg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 "
            android:textSize="16sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Akhiri Sesi Ujian?"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />

    </LinearLayout>

    <!-- ══ KONTEN DIALOG ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="26dp"
        android:paddingEnd="26dp"
        android:paddingTop="22dp"
        android:paddingBottom="26dp">

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Masukkan PIN pengawas untuk mengakhiri sesi"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12.5sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="20dp" />

    <!-- PIN label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PIN PENGAWAS"
        android:textColor="@color/colorTextSecondary"
        android:textSize="9.5sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- PIN input — minimal, centered -->
    <EditText
        android:id="@+id/etPin"
        android:layout_width="148dp"
        android:layout_height="50dp"
        android:background="@drawable/bg_pin_input"
        android:gravity="center"
        android:hint="• • • •"
        android:inputType="numberPassword"
        android:maxLength="8"
        android:textColor="@color/colorTextPrimary"
        android:textColorHint="@color/colorTextHint"
        android:textSize="20sp"
        android:letterSpacing="0.25"
        android:layout_marginBottom="22dp" />

    <!-- Confirm -->
    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/bg_btn_confirm"
        android:text="Konfirmasi Keluar"
        android:textColor="@color/white"
        android:textSize="13.5sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01"
        android:layout_marginBottom="8dp" />

    <!-- Cancel -->
    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@drawable/bg_btn_cancel"
        android:text="Lanjutkan Ujian"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp"
        android:letterSpacing="-0.01" />

    </LinearLayout>

</LinearLayout>
