<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorHeaderBg">

    <!-- ── LAYER 1: Background image (gone by default, shown if splash_bg exists) ── -->
    <ImageView
        android:id="@+id/splashBgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="Splash Background" />

    <!-- ── LAYER 2: Dark overlay (gone by default, shown with bg image) ── -->
    <View
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone" />

    <!-- ── LAYER 3: Konten tengah ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp">

        <!-- Logo — ganti drawable/app_logo.png untuk custom logo -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/app_logo"
            android:scaleType="centerInside"
            android:background="#00000000"
            android:padding="0dp"
            android:contentDescription="App Logo" />

        <!-- Nama Aplikasi -->
        <TextView
            android:id="@+id/splashAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/app_title"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.02" />

        <!-- Garis pemisah dekoratif -->
        <View
            android:id="@+id/splashDivider"
            android:layout_width="60dp"
            android:layout_height="2.5dp"
            android:layout_marginTop="16dp"
            android:background="#80FFFFFF" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/app_description"
            android:textColor="#CCFFFFFF"
            android:textSize="13.5sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />

        <!-- Badge Secure -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_badge_secure"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡  SECURE EXAM MODE"
                android:textColor="@color/colorPrimary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── LAYER 4: Loading bar + versi di bawah ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="48dp"
        android:paddingStart="60dp"
        android:paddingEnd="60dp">

        <ProgressBar
            android:id="@+id/splashProgress"
            style="@android:style/Widget.Material.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="true"
            android:progressTint="@color/white"
            android:indeterminateTint="@color/white80"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/splashVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.1.0"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:alpha="0.6" />

    </LinearLayout>

</FrameLayout>
