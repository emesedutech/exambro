<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorHeaderBg">

    <!-- ══ TOP BAR — minimal, clean ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_topbar"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:gravity="center_vertical">

        <!-- App icon — small -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:layout_marginEnd="10dp"
            android:contentDescription="Logo" />

        <!-- URL label stack -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SESI UJIAN"
                android:textColor="#50FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:letterSpacing="0.09" />
            <TextView
                android:id="@+id/tvSiteUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memuat..."
                android:textColor="#E0FFFFFF"
                android:textSize="11.5sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Secure badge — minimal pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_secure"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 AMAN"
                android:textColor="@color/colorPrimary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══ PROGRESS BAR — 2dp thin ══ -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:progressTint="@color/colorPrimary"
        android:progressBackgroundTint="@color/colorHeaderDark"
        android:visibility="gone" />

    <!-- ══ WEBVIEW ══ -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ══ BOTTOM BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_bottom_bar"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <Button
            android:id="@+id/btnExit"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_exit_btn"
            android:text="Keluar dari Ujian"
            android:textColor="@color/colorDanger"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:paddingStart="18dp"
            android:paddingEnd="18dp" />
    </LinearLayout>

</LinearLayout>
