<?xml version="1.0" encoding="utf-8"?>
<!--
  ═══════════════════════════════════════════════════════════════
  LAYOUT HALAMAN UTAMA
  ═══════════════════════════════════════════════════════════════
  Desain:
  • Header: cover image (header_bg.png) sebagai background area atas.
    Jika header_bg.png tidak ada → fallback warna solid colorHeaderBg.
  • Overlay gelap ringan di atas header image agar teks tetap terbaca.
  • Konten header (logo + judul) menumpuk di atas cover image.
  • Satu kartu putih besar di bawah yang berisi URL input + fitur keamanan.
  • Kartu sedikit overlap ke atas (mengambang di atas garis batas header).
  • Overlap: 20dp — cukup untuk efek depth tanpa menutupi konten header.

  Ukuran gambar yang disarankan:
  • header_bg.png (cover area header halaman utama) : 1080 × 560 px
  • splash_bg.png (layar loading)                  : 1080 × 1920 px  (portrait, rasio 9:16)
  Semua gambar: format PNG atau JPG, ukuran file maksimal 500 KB.
  Resolusi terlalu rendah = pecah. Gunakan minimal 1080px lebar.
  ═══════════════════════════════════════════════════════════════
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorHeaderBg">

    <!-- ══ Semua konten (header + kartu) ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── HEADER AREA ── -->
        <FrameLayout
            android:id="@+id/headerFrame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Cover image untuk header (header_bg.png) -->
            <ImageView
                android:id="@+id/imgHeaderBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Header Background" />

            <!-- Overlay gelap di atas header image agar teks terbaca -->
            <View
                android:id="@+id/headerOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#66000000"
                android:visibility="gone" />

            <!-- Konten header — background solid sebagai fallback -->
            <LinearLayout
                android:id="@+id/headerContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="52dp"
                android:paddingBottom="40dp">

                <!-- Logo -->
                <FrameLayout
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:background="@drawable/bg_logo"
                    android:layout_marginBottom="14dp">
                    <ImageView
                        android:id="@+id/imgAppLogo"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:src="@drawable/app_logo"
                        android:scaleType="centerInside"
                        android:layerType="software"
                        android:contentDescription="Logo" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_title"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:letterSpacing="-0.02"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_description"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_secure"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒  SECURE EXAM MODE"
                        android:textColor="@color/colorPrimary"
                        android:textSize="9.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- ── KARTU UTAMA — overlap 20dp ke atas dengan negative margin ── -->
        <!-- Catatan: LinearLayout mendukung negative marginTop pada child ScrollView
             karena ScrollView adalah anak langsung; ini bekerja karena FrameLayout
             parent di atas LinearLayout ini mengizinkan clipping off. -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="-20dp"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <!-- ══ KARTU GABUNGAN: URL + Fitur Keamanan ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:elevation="12dp"
                    android:padding="20dp">

                    <!-- ─ Seksi URL UJIAN ─ -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="URL UJIAN"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9.5sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etUrl"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input"
                            android:hint="https://ujian.sekolah.id/..."
                            android:inputType="textUri"
                            android:paddingStart="13dp"
                            android:paddingEnd="12dp"
                            android:textSize="12.5sp"
                            android:textColor="@color/colorTextPrimary"
                            android:textColorHint="@color/colorTextHint"
                            android:fontFamily="monospace"
                            android:imeOptions="actionGo"
                            android:singleLine="true" />

                        <LinearLayout
                            android:id="@+id/btnScanQr"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_button_scan"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_qr_scan"
                                android:contentDescription="Scan QR Code" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider atau scan -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View android:layout_width="0dp" android:layout_height="1dp"
                            android:layout_weight="1" android:background="@color/colorDivider" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="atau scan QR dari pengawas"
                            android:textColor="@color/colorTextHint"
                            android:textSize="10.5sp" />
                        <View android:layout_width="0dp" android:layout_height="1dp"
                            android:layout_weight="1" android:background="@color/colorDivider" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnStart"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_button_primary"
                        android:text="Mulai Ujian"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01"
                        android:layout_marginBottom="20dp" />

                    <!-- ─ Divider pemisah seksi ─ -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/colorDivider"
                        android:layout_marginBottom="16dp" />

                    <!-- ─ Seksi FITUR KEAMANAN ─ -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FITUR KEAMANAN"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9.5sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="34dp"
                        android:gravity="center_vertical">
                        <View android:layout_width="6dp" android:layout_height="6dp"
                            android:background="@drawable/bg_check" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tombol Back &amp; Home diblokir"
                            android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="34dp"
                        android:gravity="center_vertical">
                        <View android:layout_width="6dp" android:layout_height="6dp"
                            android:background="@drawable/bg_check" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fullscreen tanpa gangguan"
                            android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="34dp"
                        android:gravity="center_vertical">
                        <View android:layout_width="6dp" android:layout_height="6dp"
                            android:background="@drawable/bg_check" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Keluar hanya dengan PIN pengawas"
                            android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="34dp"
                        android:gravity="center_vertical">
                        <View android:layout_width="6dp" android:layout_height="6dp"
                            android:background="@drawable/bg_check" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Scan QR Code URL ujian"
                            android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="34dp"
                        android:gravity="center_vertical">
                        <View android:layout_width="6dp" android:layout_height="6dp"
                            android:background="@drawable/bg_check" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Screenshot &amp; perekaman diblokir"
                            android:textColor="@color/colorTextPrimary" android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ── Footer copyright ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:text="© 2026 Emes EduTech"
                    android:textColor="@color/white60"
                    android:textSize="10sp" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</FrameLayout>
